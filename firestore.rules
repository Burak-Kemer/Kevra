rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin = gerçek (anonim olmayan) bir Firebase Auth oturumu.
    // Müşteriler siteye girince otomatik ANONİM oturum açıyor (bkz.
    // js/firebase-config.js), admin panel ise gerçek e-posta/şifre ile
    // signInWithEmailAndPassword kullanıyor — sign_in_provider bu ikisini
    // ayırt etmemizi sağlıyor.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Ürünler ve kuponlar herkes tarafından okunabilir (mağaza sayfaları
    // giriş yapmamış ziyaretçilere de ürün göstermeli), yazma sadece admin.
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Müşteri kaydı/girişi, sipariş ve iade oluşturma/güncelleme tek tek
    // doküman (get/create/update) üzerinden yapılıyor — bunlar açık kalıyor
    // çünkü uygulama anonim müşteri oturumlarına ihtiyaç duyuyor. Ancak
    // KOLEKSİYONUN TAMAMINI listelemek (list) ve silmek (delete) sadece
    // admin'e açık: aksi halde herhangi bir ziyaretçi tüm müşterilerin
    // adı/telefon/adres/sipariş bilgisini tek sorguyla indirebilirdi.
    // Müşterinin "siparişlerim/iadelerim" gibi kendi verisini listelemesi
    // gereken yerler artık Cloud Functions üzerinden (Admin SDK ile, dar
    // kapsamlı sorgularla) sunuluyor — bkz. functions/index.js
    // getMyOrders / getMyReturns / registerCustomer / loginCustomer.
    match /users/{userId} {
      allow get, create, update: if request.auth != null;
      allow list, delete: if isAdmin();
    }
    match /orders/{orderId} {
      allow get, create, update: if request.auth != null;
      allow list, delete: if isAdmin();
    }
    match /returns/{returnId} {
      allow get, create, update: if request.auth != null;
      allow list, delete: if isAdmin();
    }
  }
}
