rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Ürünler ve kuponlar herkes tarafından okunabilir (mağaza sayfaları
    // giriş yapmamış ziyaretçilere de ürün göstermeli), yazma sadece
    // giriş yapmış (admin) kullanıcılara açık.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Müşteri kaydı, sipariş ve iade talepleri: müşteriler anonim
    // Firebase Auth oturumuyla giriş yapıyor (bkz. js/firebase-config.js),
    // admin panel de gerçek Firebase Auth hesabıyla giriş yapıyor.
    // İkisi de request.auth != null koşulunu sağlıyor.
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    match /returns/{returnId} {
      allow read, write: if request.auth != null;
    }
  }
}
